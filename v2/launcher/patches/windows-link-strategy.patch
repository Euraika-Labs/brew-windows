# Brew Windows v2 patch
#
# Title:      Windows link strategy: .cmd/.ps1 shims + hardlinks
# Targets:    Library/Homebrew/extend/os/keg.rb (loader),
#             Library/Homebrew/extend/os/windows/keg.rb (new)
# Upstream:   Phase 5 PR candidate. Independent of macOS/Linux
#             keg behavior. Uses the existing extend/os/<platform>/
#             pattern.
# Phase:      3 (first formula install) and Phase 5 (upstream PR)
# Rationale:  Windows has no widely-available POSIX symlinks for
#             unprivileged users. Homebrew's keg link step would
#             create dangling files. Replace make_relative_symlink
#             on Windows with a shim-generation strategy for
#             <prefix>\bin entries (.cmd + .ps1 pair) and a NTFS
#             hardlink strategy for other files (lib/, include/,
#             share/). Hardlinks fall back to copies for cross-
#             volume edges. The shim files carry a marker so a
#             later `brew uninstall` and any conflict detection
#             can safely reason about which files brew owns.
# Preserves:  macOS/Linux untouched. The override only loads under
#             OS.windows?.
diff --git a/Library/Homebrew/extend/os/keg.rb b/Library/Homebrew/extend/os/keg.rb
index 733768b..55c756b 100644
--- a/Library/Homebrew/extend/os/keg.rb
+++ b/Library/Homebrew/extend/os/keg.rb
@@ -5,4 +5,6 @@ if OS.mac?
   require "extend/os/mac/keg"
 elsif OS.linux?
   require "extend/os/linux/keg"
+elsif OS.windows?
+  require "extend/os/windows/keg"
 end
diff --git a/Library/Homebrew/extend/os/windows/keg.rb b/Library/Homebrew/extend/os/windows/keg.rb
new file mode 100644
index 0000000..d16658d
--- /dev/null
+++ b/Library/Homebrew/extend/os/windows/keg.rb
@@ -0,0 +1,149 @@
+# typed: true
+# frozen_string_literal: true
+
+require "fileutils"
+
+module OS
+  module Windows
+    # Windows linking strategy. POSIX symlinks are unavailable to
+    # unprivileged users on Windows (without Developer Mode), and
+    # storing them as plain-text dangling links breaks every Homebrew
+    # consumer. Instead, for files that end up under
+    # <prefix>\bin\, generate a `.cmd` + `.ps1` shim pair pointing
+    # at the keg-installed target. For other files, try a NTFS hard
+    # link (same-volume only, no admin required), fall back to copy.
+    # Directories are left to the upstream code path.
+    module KegLinkStrategy
+      BREW_WINDOWS_MARKER = "Generated by Brew Windows. Do not edit."
+
+      sig { params(dst: Pathname, src: Pathname, verbose: T::Boolean, dry_run: T::Boolean, overwrite: T::Boolean).void }
+      def make_relative_symlink(dst, src, verbose: false, dry_run: false, overwrite: false)
+        return super unless src.file?
+
+        if dry_run
+          puts dst if verbose || !dry_run
+          return
+        end
+
+        # Resolve absolute target path. dst is the planned link
+        # location; src is the keg-relative source under HOMEBREW_CELLAR.
+        target = src.realpath
+
+        # Reroute bin/ links to the LAUNCHER prefix's bin so the user's
+        # User PATH (which install.ps1 added) actually surfaces the
+        # installed formula. Without this, files land in the Homebrew
+        # internal bin (<prefix>/runtime/homebrew/bin) which is never
+        # on User PATH.
+        in_homebrew_bin = homebrew_bin_dir?(dst)
+        if in_homebrew_bin
+          launcher_prefix = ENV.fetch("HOMEBREW_WINDOWS_PREFIX", nil)
+          if launcher_prefix && !launcher_prefix.empty?
+            dst = Pathname.new(File.join(launcher_prefix, "bin", dst.basename.to_s))
+          end
+        end
+        in_bin = in_homebrew_bin || bin_dir?(dst)
+
+        if dst.exist? || dst.symlink?
+          if overwrite
+            safe_remove(dst)
+          else
+            if in_bin
+              # Check the marker convention: refuse to clobber a
+              # file we didn't write ourselves.
+              unless brew_windows_managed?(dst)
+                raise Keg::ConflictError.new(self, src.relative_path_from(path), dst, Errno::EEXIST.new(dst.to_s))
+              end
+              safe_remove(dst)
+            else
+              raise Keg::ConflictError.new(self, src.relative_path_from(path), dst, Errno::EEXIST.new(dst.to_s))
+            end
+          end
+        end
+
+        FileUtils.mkdir_p(dst.dirname)
+
+        if in_bin
+          base = dst.basename.to_s
+          # Strip a trailing .exe so `ripgrep.exe` in the Cellar
+          # becomes `ripgrep.cmd` + `ripgrep.ps1` shims in
+          # <prefix>\bin (typed as just `ripgrep` on a PowerShell
+          # prompt). For non-.exe files (scripts, completion data
+          # that happens to live in bin), shim under the original
+          # name with both extensions added.
+          shim_name = base.sub(/\.exe\z/i, "")
+          write_cmd_shim(dst.dirname/"#{shim_name}.cmd", shim_name, target)
+          write_ps1_shim(dst.dirname/"#{shim_name}.ps1", target)
+          return
+        end
+
+        # Non-bin: try hard link, fall back to copy.
+        begin
+          File.link(target.to_s, dst.to_s)
+        rescue SystemCallError
+          FileUtils.cp(target.to_s, dst.to_s)
+        end
+      rescue Errno::EACCES => e
+        raise Keg::DirectoryNotWritableError.new(self, src.relative_path_from(path), dst, e)
+      rescue SystemCallError => e
+        raise Keg::LinkError.new(self, src.relative_path_from(path), dst, e)
+      end
+
+      private
+
+      sig { params(dst: Pathname).returns(T::Boolean) }
+      def bin_dir?(dst)
+        prefix = ENV.fetch("HOMEBREW_WINDOWS_PREFIX", nil) || ENV.fetch("HOMEBREW_PREFIX", nil)
+        return false if prefix.nil? || prefix.empty?
+
+        File.expand_path(dst.dirname.to_s).casecmp(File.expand_path(File.join(prefix, "bin"))).zero?
+      end
+
+      sig { params(dst: Pathname).returns(T::Boolean) }
+      def homebrew_bin_dir?(dst)
+        prefix = ENV.fetch("HOMEBREW_PREFIX", nil)
+        return false if prefix.nil? || prefix.empty?
+
+        File.expand_path(dst.dirname.to_s).casecmp(File.expand_path(File.join(prefix, "bin"))).zero?
+      end
+
+      sig { params(dst: Pathname).returns(T::Boolean) }
+      def brew_windows_managed?(dst)
+        return false unless dst.file?
+
+        head = File.open(dst.to_s, "rb") { |f| f.read(256) }.to_s
+        head.include?(BREW_WINDOWS_MARKER)
+      rescue StandardError
+        false
+      end
+
+      sig { params(path: Pathname).void }
+      def safe_remove(path)
+        path.unlink if path.exist? || path.symlink?
+      end
+
+      sig { params(cmd_path: Pathname, name: String, target: Pathname).void }
+      def write_cmd_shim(cmd_path, name, target)
+        content = +""
+        content << "@echo off\r\n"
+        content << "rem #{BREW_WINDOWS_MARKER}\r\n"
+        content << "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%~dp0#{name}.ps1\" %*\r\n"
+        content << "exit /b %ERRORLEVEL%\r\n"
+        File.binwrite(cmd_path.to_s, content)
+      end
+
+      sig { params(ps1_path: Pathname, target: Pathname).void }
+      def write_ps1_shim(ps1_path, target)
+        escaped = target.to_s.gsub("'", "''")
+        content = +""
+        content << "# #{BREW_WINDOWS_MARKER}\r\n"
+        content << "$ErrorActionPreference = 'Stop'\r\n"
+        content << "$target = '#{escaped}'\r\n"
+        content << "& $target @args\r\n"
+        content << "exit $LASTEXITCODE\r\n"
+        File.binwrite(ps1_path.to_s, content)
+      end
+    end
+  end
+end
+
+Keg.prepend(OS::Windows::KegLinkStrategy)
