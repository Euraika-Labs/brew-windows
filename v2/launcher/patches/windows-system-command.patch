# Brew Windows v2 patch
#
# Title:      Windows-friendly SystemCommand#exec3 via Process.spawn
# Targets:    Library/Homebrew/system_command.rb (loader require),
#             Library/Homebrew/extend/os/system_command.rb (new loader),
#             Library/Homebrew/extend/os/windows/system_command.rb (new override)
# Upstream:   Phase 5 PR candidate (substantial - enables a broad
#             swath of brew commands on Windows). Uses the existing
#             extend/os/<platform>/<module>.rb pattern.
# Phase:      2 (doctor parity) and Phase 5 (upstream PR)
# Rationale:  SystemCommand#exec3 is upstream Homebrew's central
#             primitive for invoking a child process with separate
#             stdin/stdout/stderr pipes. The implementation uses
#             fork+exec with Process::UID.change_privilege - both
#             unimplemented on Windows. brew config, brew doctor,
#             brew install, brew tap, and most brew commands route
#             through this. Windows Ruby provides Process.spawn which
#             returns a PID directly (no fork) and accepts the same
#             env/options/redirect arguments. The drop-in replacement
#             preserves the [stdin, stdout, stderr, wait_thread] return
#             contract that callers depend on.
#
#             This revision also:
#             - Strips POSIX-only spawn options (:pgroup,
#               :unsetenv_others, :close_others) that Windows
#               Process.spawn rejects with `wrong exec option symbol`.
#             - Overrides command_prefix to drop the macOS/Linux
#               `/usr/bin/env VAR=val` wrapper - Process.spawn accepts
#               the env hash directly and /usr/bin/env doesn't exist
#               on Windows.
#             - Detects `#!/.../bash` shebang shims (e.g.
#               Library/Homebrew/shims/shared/git) and routes them
#               through the vendored bash.exe sibling of git.exe.
#               Windows CreateProcess cannot exec a script with a
#               shebang directly.
#             - Hard-codes COLUMNS=80 instead of calling Tty.width.
#               Tty.width shells out to /bin/stty which doesn't exist
#               on Windows (see also windows-tty.patch for the host
#               side).
# Preserves:  macOS/Linux unchanged. The override only loads when
#             RbConfig::CONFIG["host_os"] matches Windows. Existing
#             fork-based code still runs everywhere else.
diff --git a/Library/Homebrew/extend/os/system_command.rb b/Library/Homebrew/extend/os/system_command.rb
new file mode 100644
index 0000000..d72bab6
--- /dev/null
+++ b/Library/Homebrew/extend/os/system_command.rb
@@ -0,0 +1,4 @@
+# typed: strict
+# frozen_string_literal: true
+
+require_relative "windows/system_command" if RbConfig::CONFIG["host_os"].match?(/mswin|mingw|cygwin/)
diff --git a/Library/Homebrew/extend/os/windows/system_command.rb b/Library/Homebrew/extend/os/windows/system_command.rb
new file mode 100644
index 0000000..6c80343
--- /dev/null
+++ b/Library/Homebrew/extend/os/windows/system_command.rb
@@ -0,0 +1,86 @@
+# typed: true
+# frozen_string_literal: true
+
+module OS
+  module Windows
+    module SystemCommandWrapper
+      # Replace the fork+exec implementation with Process.spawn, which is
+      # the supported way to launch a child process on Windows (Ruby's
+      # fork is unimplemented there). Drops the Process::UID privilege
+      # handoff since Windows has no setuid model.
+      # Options that the upstream fork+exec path accepts but Windows
+      # Process.spawn rejects (`wrong exec option symbol`). Strip them
+      # silently - they are POSIX-only semantics (process groups, uid
+      # handoff) that have no Windows equivalent.
+      UNSUPPORTED_SPAWN_OPTIONS = [:pgroup, :unsetenv_others, :close_others].freeze
+
+      # Upstream wraps every non-sudo invocation with `/usr/bin/env VAR=val`
+      # which works on macOS/Linux but doesn't exist as a native Windows
+      # path. Process.spawn accepts the env hash directly so the wrapper
+      # adds no value here.
+      def command_prefix
+        sudo? ? super : []
+      end
+
+      def exec3(env, executable, *args, **options)
+        in_r, in_w = IO.pipe
+        options[:in] = in_r
+        in_w.sync = true
+
+        out_r, out_w = IO.pipe
+        options[:out] = out_w
+
+        err_r, err_w = IO.pipe
+        options[:err] = err_w
+
+        UNSUPPORTED_SPAWN_OPTIONS.each { |key| options.delete(key) }
+
+        # Bash shebang shims (e.g. Library/Homebrew/shims/shared/git)
+        # can't be exec'd directly by Windows CreateProcess. Detect the
+        # `#!/.../bash` header and route through the vendored bash.exe.
+        if executable.to_s.is_a?(String) && File.file?(executable.to_s)
+          first_line = File.open(executable.to_s, "rb") { |f| f.read(256) }.to_s
+          if first_line.start_with?("#!") && first_line.include?("bash")
+            # Locate the vendored bash relative to git.exe (mingit ships both).
+            git_path = ENV["HOMEBREW_GIT_PATH"].to_s
+            bash = ENV["HOMEBREW_BASH"]
+            if (bash.nil? || bash.empty?) && !git_path.empty?
+              # git_path is .../runtime/mingit/cmd/git.exe; bash lives at
+              # .../runtime/mingit/usr/bin/bash.exe (sibling of `cmd`).
+              mingit_root = File.dirname(File.dirname(git_path))
+              bash = File.join(mingit_root, "usr", "bin", "bash.exe")
+            end
+            if bash && File.file?(bash)
+              args = [executable.to_s, *args]
+              executable = bash
+            end
+          end
+        end
+
+        # `Tty.width` shells out to `/bin/stty` which doesn't exist on
+        # Windows. Use a constant value instead - this only sets COLUMNS
+        # for the child process and doesn't affect anything Windows tools
+        # care about.
+        pid = Process.spawn(
+          env.merge({ "COLUMNS" => "80" }),
+          executable,
+          *args,
+          **options,
+        )
+        wait_thr = Process.detach(pid)
+
+        [in_w, out_r, err_r, wait_thr]
+      rescue
+        in_w&.close
+        out_r&.close
+        err_r&.close
+        raise
+      ensure
+        in_r&.close
+        out_w&.close
+      end
+    end
+  end
+end
+
+SystemCommand.prepend(OS::Windows::SystemCommandWrapper)
